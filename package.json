{
  "name": "mdowner",
  "version": "2.7.1",
  "description": "A Typora-like Markdown editor",
  "main": "src/main/index.js",
  "type": "commonjs",
  "author": "BEIZHOU",
  "license": "MIT",
  "scripts": {
    "build:renderer": "esbuild src/renderer/js/app.js --bundle --outfile=src/renderer/js/bundle.js --format=iife --platform=browser",
    "start": "npm run build:renderer && electron .",
    "build": "npm run build:renderer && electron-builder",
    "build:win": "npm run build:renderer && electron-builder --win && python scripts/build-post.py",
    "build:mac": "npm run build:renderer && electron-builder --mac",
    "build:all": "npm run build:win"
  },
  "build": {
    "appId": "com.mdowner.app",
    "productName": "MDowner",
    "afterPack": "scripts/after-pack.js",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icons/icon.ico",
      "fileAssociations": [
        {
          "ext": "md",
          "name": "MDowner.Markdown",
          "description": "Markdown 文档",
          "role": "Editor"
        },
        {
          "ext": "markdown",
          "name": "MDowner.Markdown",
          "description": "Markdown 文档",
          "role": "Editor"
        },
        {
          "ext": "txt",
          "name": "MDowner.Text",
          "description": "文本文件",
          "role": "Editor"
        }
      ],
      "signAndEditExecutable": false
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icons/icon.png",
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "artifactName": "${productName}_${version}_${arch}.dmg"
    },
    "portable": {
      "artifactName": "${productName}_Portable_${version}.exe"
    },
    "nsis": {
      "artifactName": "${productName}_Setup_${version}.exe",
      "installerIcon": "assets/icons/icon.ico",
      "installerHeaderIcon": "assets/icons/icon.ico",
      "uninstallerIcon": "assets/icons/icon.ico",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "include": "scripts/installer.nsh"
    },
    "asar": true,
    "asarUnpack": [
      "**/*.node",
      "**/*.dll"
    ]
  },
  "dependencies": {
    "@tiptap/core": "^2.1.13",
    "@tiptap/extension-character-count": "^2.1.13",
    "@tiptap/extension-code-block-lowlight": "^2.1.13",
    "@tiptap/extension-highlight": "^2.1.13",
    "@tiptap/extension-image": "^2.1.13",
    "@tiptap/extension-link": "^2.1.13",
    "@tiptap/extension-placeholder": "^2.1.13",
    "@tiptap/extension-table": "^2.1.13",
    "@tiptap/extension-table-cell": "^2.1.13",
    "@tiptap/extension-table-header": "^2.1.13",
    "@tiptap/extension-table-row": "^2.1.13",
    "@tiptap/extension-task-item": "^2.27.2",
    "@tiptap/extension-task-list": "^2.1.13",
    "@tiptap/pm": "^2.1.13",
    "@tiptap/starter-kit": "^2.1.13",
    "highlight.js": "^11.9.0",
    "lowlight": "^3.1.0",
    "marked": "^11.1.0",
    "puppeteer-core": "^21.7.0",
    "turndown": "^7.2.4"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "electron": "^25.9.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0"
  }
}
