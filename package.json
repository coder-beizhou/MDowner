{
  "name": "mdowner",
  "version": "1.1.0",
  "description": "A Typora-like Markdown editor for Windows",
  "main": "src/main/index.js",
  "type": "commonjs",
  "author": "MDowner Team",
  "license": "MIT",
  "scripts": {
    "build:renderer": "esbuild src/renderer/js/app.js --bundle --outfile=src/renderer/js/bundle.js --format=iife --platform=browser",
    "start": "npm run build:renderer && electron .",
    "build": "npm run build:renderer && electron-builder",
    "build:win": "npm run build:renderer && electron-builder --win",
    "build:all": "npm run build:renderer && electron-builder --win && python scripts/build-post.py"
  },
  "build": {
    "appId": "com.mdowner.app",
    "productName": "MDowner",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icons/icon.ico",
      "signAndEditExecutable": false
    },
    "portable": {
      "artifactName": "MDowner-Portable.exe"
    },
    "nsis": {
      "artifactName": "MDowner-Setup.exe",
      "installerIcon": "assets/icons/icon.ico",
      "installerHeaderIcon": "assets/icons/icon.ico",
      "uninstallerIcon": "assets/icons/icon.ico",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "asar": true,
    "asarUnpack": [
      "**/*.node",
      "**/*.dll"
    ]
  },
  "dependencies": {
    "@tiptap/core": "^2.1.13",
    "@tiptap/extension-character-count": "^2.1.13",
    "@tiptap/extension-code-block-lowlight": "^2.1.13",
    "@tiptap/extension-highlight": "^2.1.13",
    "@tiptap/extension-image": "^2.1.13",
    "@tiptap/extension-link": "^2.1.13",
    "@tiptap/extension-placeholder": "^2.1.13",
    "@tiptap/extension-table": "^2.1.13",
    "@tiptap/extension-table-cell": "^2.1.13",
    "@tiptap/extension-table-header": "^2.1.13",
    "@tiptap/extension-table-row": "^2.1.13",
    "@tiptap/extension-task-item": "^2.27.2",
    "@tiptap/extension-task-list": "^2.1.13",
    "@tiptap/pm": "^2.1.13",
    "@tiptap/starter-kit": "^2.1.13",
    "highlight.js": "^11.9.0",
    "lowlight": "^3.1.0",
    "marked": "^11.1.0",
    "puppeteer-core": "^21.7.0",
    "turndown": "^7.2.4"
  },
  "devDependencies": {
    "electron": "^25.9.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0"
  }
}
